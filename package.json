{
  "name": "arcpay",
  "version": "0.1.0",
  "private": true,
  "description": "Private autonomous treasury for AI agents on Solana.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run test --workspaces --if-present && npm run build --workspaces --if-present",
    "security:audit": "npm audit --omit=dev",
    "test": "npm run test --workspaces --if-present",
    "build:program": "cd packages/program && anchor build",
    "test:program": "cd packages/program && anchor test"
  },
  "overrides": {
    "@ethersproject/signing-key": {
      "elliptic": "6.6.1"
    },
    "jsonpath@1.3.0": {
      "underscore": "1.13.8"
    },
    "next@16.2.6": {
      "postcss": "8.5.14"
    },
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  }
}
